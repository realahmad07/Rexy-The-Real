# Handle binary files correctly to prevent corruption and ensure fast GitHub checks
*.mp4 binary
*.jpg binary
*.png binary
*.gif binary
*.pdf binary
*.svg binary

# Force Unix line endings for text files
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.json text eol=lf
*.md text eol=lf
*.html text eol=lf
*.sol text eol=lf
*.rs text eol=lf

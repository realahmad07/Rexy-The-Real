rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - email: string (optional)
    //   - walletAddress: string (optional)
    //   - createdAt: timestamp (required)
    //   - role: string (required, enum: ['user', 'admin'])
    //
    // Collection: audits
    // Document ID: {auditId}
    // Fields:
    //   - id: string (required)
    //   - userId: string (required)
    //   - codeHash: string (required)
    //   - codeSnippet: string (optional)
    //   - result: map (required)
    //   - timestamp: timestamp (required)
    //   - status: string (required, enum: ['success', 'failed'])
    //   - cost: number (optional)
    //   - nftMinted: bool (optional)
    //   - nftAddress: string (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "247280@students.au.edu.pk" && request.auth.token.email_verified == true));
    }

    function isRecent(time) {
      return time > request.time - duration.value(5, 'm') &&
             time <= request.time;
    }

    function isValidUser(data) {
      let requiredFields = ['uid', 'createdAt', 'role'];
      return data.keys().hasAll(requiredFields) &&
             data.uid is string &&
             data.role in ['user', 'admin'] &&
             data.createdAt is timestamp &&
             (!('lastActive' in data) || data.lastActive is timestamp) &&
             (!('walletAddress' in data) || data.walletAddress is string);
    }

    function isValidAudit(data) {
      return data.keys().hasAll(['userId', 'codeHash', 'score', 'summary', 'issues', 'timestamp', 'status']) &&
             data.userId is string &&
             data.codeHash is string &&
             data.score is number &&
             data.summary is string &&
             data.issues is list &&
             data.timestamp is timestamp &&
             data.status in ['success', 'failed'] &&
             // Size constraints
             data.codeHash.size() <= 128 &&
             data.summary.size() <= 50000 &&
             data.issues.size() <= 100;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin() || (!isAuthenticated() && userId.size() >= 32 && userId.size() <= 44);
      allow create: if isValidUser(request.resource.data) && 
                    (
                      (isAuthenticated() && isOwner(userId) && request.resource.data.role == 'user') || 
                      (!isAuthenticated() && userId == request.resource.data.uid && userId.size() >= 32 && userId.size() <= 44 && request.resource.data.role == 'user') ||
                      isAdmin()
                    ) && isRecent(request.resource.data.createdAt);
      allow update: if isValidUser(request.resource.data) && 
                    (
                      isAdmin() || 
                      (isAuthenticated() && isOwner(userId) && request.resource.data.role == resource.data.role) ||
                      (!isAuthenticated() && userId == resource.id && userId.size() >= 32 && userId.size() <= 44 && request.resource.data.role == resource.data.role)
                    );
    }

    match /audits/{auditId} {
      allow read: if true;
      allow create: if isValidAudit(request.resource.data) && 
                    (
                      (isAuthenticated() && (request.resource.data.userId == request.auth.uid || isAdmin())) ||
                      // Allow anonymous writes for Solana wallet users
                      (!isAuthenticated() && request.resource.data.userId.size() >= 32 && request.resource.data.userId.size() <= 44)
                    );
      allow update: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
